17949223518371582, "adapter_response": {"_message": "SELECT 270", "code": "SELECT", "rows_affected": 270}, "message": "SELECT 270", "failures": null, "unique_id": "model.nse_eod_pipeline.mart_volatility", "compiled": true, "compiled_code": "with base as (\n    select * from \"nse_warehouse\".\"marts\".\"mart_eod_returns\"\n),\n\nvolatility as (\n    select\n        ticker,\n        trade_date,\n        daily_return_pct,\n        round(stddev(daily_return_pct) over (\n            partition by ticker\n            order by trade_date\n            rows between 19 preceding and current row\n        ), 4) as vol_20d\n    from base\n)\n\nselect * from volatility", "relation_name": "\"nse_warehouse\".\"marts\".\"mart_volatility\"", "batch_results": null}], "elapsed_time": 1.224653720855713, "args": {"use_colors": true, "project_dir": "/opt/airflow/dbt", "use_colors_file": true, "log_path": "/opt/airflow/dbt/logs", "validate_macro_args": false, "require_all_warnings_handled_by_warn_error": false, "log_level_file": "debug", "strict_mode": false, "favor_state": false, "require_generic_test_arguments_property": true, "use_fast_test_edges": false, "cache_selected_only": false, "skip_nodes_if_on_run_start_fails": false, "source_freshness_run_project_hooks": true, "print": true, "which": "run", "require_nested_cumulative_type_params": false, "partial_parse_file_diff": true, "profiles_dir": "/opt/airflow/dbt", "log_format": "default", "partial_parse": true, "printer_width": 80, "exclude": [], "require_batched_execution_for_custom_microbatch_strategy": false, "sqlparse": {"MAX_GROUPING_DEPTH": null, "MAX_GROUPING_TOKENS": null}, "show_all_deprecations": false, "quiet": false, "select": [], "state_modified_compare_vars": false, "state_modified_compare_more_unrendered_values": false, "upload_to_artifacts_ingest_api": false, "version_check": true, "require_ref_searches_node_package_before_root": false, "require_resource_names_without_spaces": true, "send_anonymous_usage_stats": true, "