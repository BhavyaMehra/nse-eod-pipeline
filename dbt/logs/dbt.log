  create  table "nse_warehouse"."staging_marts"."mart_eod_returns__dbt_tmp"
  
  
    as
  
  (
    with base as (
    select * from "nse_warehouse"."staging_staging"."stg_eod_prices"
),

returns as (
    select 
        ticker,
        trade_date,
        close,
        lag(close) over (partition by ticker order by trade_date) as prev_close,
        round((close - lag(close) over (partition by ticker order by trade_date)) / nullif(lag(close) over (partition by ticker order by trade_date), 0) * 100, 4) 
            as daily_return_pct
    from base
)

select * from returns
  );
  
